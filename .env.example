# Database
POSTGRES_USER=plateflow
POSTGRES_PASSWORD=plateflow_secret
POSTGRES_DB=plateflow
DATABASE_URL=postgresql+asyncpg://plateflow:plateflow_secret@db:5432/plateflow

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=PlateFlow
APP_ENV=development
DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Admin
FIRST_ADMIN_EMAIL=admin@plateflow.com
FIRST_ADMIN_PASSWORD=admin123
